    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "basic-ftp": "^6.0.1",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2"
  },
  "overrides": {
    "undici": "^6.27.0"
  }
}
